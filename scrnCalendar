Screens:
  scrnCalendar:
    Properties:
      Fill: =RGBA(0, 0, 0, 0)
      LoadingSpinnerColor: =RGBA(0, 120, 212, 1)
      OnVisible: |-
        =Set(varCurrentMonth, DateAdd(Today(), -Day(Today()) + 1, TimeUnit.Days));
        ClearCollect(
            colCalendarDays,
            ForAll(
                Sequence(42),
                {
                    DayDate: DateAdd(
                        varCurrentMonth,
                        ThisRecord.Value - Weekday(varCurrentMonth),
                        TimeUnit.Days
                    )
                }
            )
        )
    Children:
      - labelMonth:
          Control: Label@2.5.1
          Properties:
            BorderColor: =RGBA(0, 0, 0, 0)
            BorderStyle: =BorderStyle.None
            BorderThickness: =2
            Color: =RGBA(50, 49, 48, 1)
            DisabledBorderColor: =RGBA(0, 0, 0, 0)
            DisabledColor: =RGBA(161, 159, 157, 1)
            FocusedBorderThickness: =4
            Font: =Font.'Segoe UI'
            Height: =48
            Size: =18
            Text: =Text(varCurrentMonth, "[$-en-US]mmmm yyyy")
            X: =13
            Y: =4
      - iconPreviousMonth:
          Control: Classic/Icon@2.5.0
          Properties:
            BorderColor: =RGBA(0, 0, 0, 0)
            Color: =RGBA(0, 120, 212, 1)
            DisabledBorderColor: =RGBA(245, 245, 245, 1)
            DisabledColor: =RGBA(225, 223, 221, 1)
            DisabledFill: =RGBA(0, 0, 0, 0)
            FocusedBorderThickness: =4
            Height: =39
            HoverBorderColor: =RGBA(0, 0, 0, 0)
            HoverColor: =RGBA(16, 110, 190, 1)
            HoverFill: =RGBA(0, 0, 0, 0)
            Icon: =Icon.BackArrow
            OnSelect: |-
              =Set(varCurrentMonth, DateAdd(varCurrentMonth, -1, TimeUnit.Months));
              ClearCollect(
                  colCalendarDays,
                  ForAll(
                      Sequence(42),
                      {
                          DayDate: DateAdd(
                              varCurrentMonth,
                              ThisRecord.Value - Weekday(varCurrentMonth),
                              TimeUnit.Days
                          )
                      }
                  )
              )
            PressedBorderColor: =RGBA(0, 0, 0, 0)
            PressedColor: =RGBA(16, 110, 190, 1)
            PressedFill: =RGBA(0, 0, 0, 0)
            Width: =53
            X: =187
            Y: =8
      - iconNextMonth:
          Control: Classic/Icon@2.5.0
          Properties:
            BorderColor: =RGBA(0, 0, 0, 0)
            Color: =RGBA(0, 120, 212, 1)
            DisabledBorderColor: =RGBA(245, 245, 245, 1)
            DisabledColor: =RGBA(225, 223, 221, 1)
            DisabledFill: =RGBA(0, 0, 0, 0)
            FocusedBorderThickness: =4
            Height: =39
            HoverBorderColor: =RGBA(0, 0, 0, 0)
            HoverColor: =RGBA(16, 110, 190, 1)
            HoverFill: =RGBA(0, 0, 0, 0)
            Icon: =Icon.NextArrow
            OnSelect: |-
              =Set(varCurrentMonth, DateAdd(varCurrentMonth, 1, TimeUnit.Months));
              ClearCollect(
                  colCalendarDays,
                  ForAll(
                      Sequence(42),
                      {
                          DayDate: DateAdd(
                              varCurrentMonth,
                              ThisRecord.Value - Weekday(varCurrentMonth),
                              TimeUnit.Days
                          )
                      }
                  )
              )
            PressedBorderColor: =RGBA(0, 0, 0, 0)
            PressedColor: =RGBA(16, 110, 190, 1)
            PressedFill: =RGBA(0, 0, 0, 0)
            Width: =42
            X: =240
            Y: =8
      - toggleShowAllApproved:
          Control: Toggle@1.1.5
          Properties:
            Height: =48
            Label: ="Show All Approved"
            OnCheck: =Set(varShowAll, true)
            OnUncheck: =Set(varShowAll, false)
            Width: =210
