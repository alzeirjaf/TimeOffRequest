                        Month(ThisItem.DayDate) = Month(varCurrentMonth),
                        Text(ThisItem.DayDate, "d"),
                        ""
                    )
                  Width: =42
                  X: =17
                  Y: =4
            - galTimeOffPerDay:
                Control: Gallery@2.15.0
                Variant: BrowseLayout_Vertical_TwoTextOneImageVariant_ver5.0
                Properties:
                  BorderColor: =RGBA(245, 245, 245, 1)
                  Height: =104
                  Items: |-
                    =Filter(
                        TimeOffRequests,
                        Status.Value = "Approved",
                        ThisItem.DayDate >= 'Start Date',
                        ThisItem.DayDate <= 'End Date',
                        varShowAll || Title = User().FullName
                    )
                  TemplateSize: =80
                  Width: =192
                Children:
                  - labelApprovedRequest:
                      Control: Label@2.5.1
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderStyle: =BorderStyle.None
                        BorderThickness: =2
                        Color: =RGBA(50, 49, 48, 1)
                        DisabledBorderColor: =RGBA(0, 0, 0, 0)
                        DisabledColor: =RGBA(161, 159, 157, 1)
                        FocusedBorderThickness: =4
                        Font: =Font.'Segoe UI'
                        Height: =87
                        OnSelect: =Select(Parent)
                        Text: |-
                          =If(varShowAll, ThisItem.Title & ": " & ThisItem.'Leave Type'.Value,ThisItem.'Leave Type'.Value)
                        Width: =169
                        X: =20
                        Y: =8
